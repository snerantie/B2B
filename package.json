{
  "name": "fintech-marketplace",
  "version": "1.0.0",
  "description": "B2B Financial Services & Fintech Marketplace",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install",
    "db:setup": "psql fintech_marketplace < server/database/schema.sql",
    "db:seed": "psql fintech_marketplace < server/database/seed.sql",
    "db:init": "node server/scripts/initDb.js",
    "db:init:seed": "node server/scripts/initDb.js --seed"
  },
  "keywords": ["b2b", "marketplace", "fintech", "financial-services"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
